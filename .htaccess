# Verifique se o index.php existe na raiz do servidor
# Certifique-se de que as permissões de pasta são 755 e de arquivos são 644
# Adicione este .htaccess se estiver usando Apache:

DirectoryIndex index.php
Options -Indexes +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.php [L]
</IfModule>
